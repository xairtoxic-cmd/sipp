# Sipp environment variables
# The app runs fully without these (seed data + localStorage + free Leaflet map tiles).
# Fill these in to wire up the real backend + Google Places import.

# --- Supabase (auth + database) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google Maps Platform (server-side Places import + optional Maps JS) ---
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Real café photos (Google Places Photos API) ---
# 1) Set GOOGLE_MAPS_API_KEY above (Places API enabled, billing on).
# 2) Set the flag below to "1" so the app fetches real photos via /api/places/photo.
#    Without this, cafés keep their stock placeholder images.
NEXT_PUBLIC_PLACES_PHOTOS=

# Admin gate (email allowed to access /admin import tools)
NEXT_PUBLIC_ADMIN_EMAIL=canada@surayyagroup.com
